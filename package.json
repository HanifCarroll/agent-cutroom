{
  "name": "agent-cutroom",
  "version": "0.1.0",
  "description": "Agent-accessible tools for reviewing, planning, and rendering video edits from footage, transcripts, frames, and silence metadata.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "author": "Hanif Carroll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HanifCarroll/agent-cutroom.git"
  },
  "bugs": {
    "url": "https://github.com/HanifCarroll/agent-cutroom/issues"
  },
  "homepage": "https://github.com/HanifCarroll/agent-cutroom#readme",
  "bin": {
    "agent-cutroom": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22"
  }
}
